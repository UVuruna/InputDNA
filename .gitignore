# ─────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
*.whl

# ─────────────────────────────────────────────────────────────
# Virtual environments
# ─────────────────────────────────────────────────────────────
venv/
.venv/
env/
.env
.env.*

# ─────────────────────────────────────────────────────────────
# IDE / Editor
# ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# ─────────────────────────────────────────────────────────────
# Claude Code
# ─────────────────────────────────────────────────────────────
.claude/

# ─────────────────────────────────────────────────────────────
# OS files
# ─────────────────────────────────────────────────────────────
Thumbs.db
Desktop.ini
.DS_Store

# ─────────────────────────────────────────────────────────────
# Temp / scratch
# ─────────────────────────────────────────────────────────────
/temp/
/tmp/
*.tmp
*.bak
*.log

# ─────────────────────────────────────────────────────────────
# Database files (generated at runtime)
# ─────────────────────────────────────────────────────────────
data/**/*.db
data/**/*.db-wal
data/**/*.db-shm

# ─────────────────────────────────────────────────────────────
# Build / Setup artifacts
# ─────────────────────────────────────────────────────────────
setup/cert/
*.spec

# ─────────────────────────────────────────────────────────────
# ML models / large binary artifacts
# ─────────────────────────────────────────────────────────────
*.pt
*.pth
*.onnx
*.pkl
*.h5
